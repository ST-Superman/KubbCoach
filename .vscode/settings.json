{
  // Swift Language Server Configuration
  "swift.path": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin",
  "swift.SDK": "/Applications/Xcode.app/Contents/Developer/Platforms/iPhoneSimulator.platform/Developer/SDKs/iPhoneSimulator.sdk",
  "swift.buildPath": "${workspaceFolder}/.build",

  // Editor Configuration
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.formatOnSave": true,
  "editor.rulers": [100],
  "editor.bracketPairColorization.enabled": true,

  // File Associations
  "files.associations": {
    "*.swift": "swift"
  },

  // Search Exclusions (keep VS Code fast)
  "files.exclude": {
    "**/.build": true,
    "**/DerivedData": true
  },
  "search.exclude": {
    "**/.build": true,
    "**/DerivedData": true,
    "*.xcodeproj": true,
    "*.xcworkspace": true
  },

  // Terminal Configuration
  "terminal.integrated.defaultProfile.osx": "zsh",

  // Git Configuration
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true
}
